{
  "expo": {
    "name": "Crosses",
    "slug": "Crosses",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "crosses",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "PUZ File",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": [
              "com.crosses.puz"
            ]
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.crosses.puz",
            "UTTypeDescription": "PUZ File",
            "UTTypeConformsTo": [
              "public.data"
            ],
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "puz"
              ]
            }
          }
        ]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Crosses",
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "file",
              "mimeType": "*/*",
              "host": "*",
              "pathPattern": ".*\\.puz"
            },
            {
              "scheme": "content",
              "mimeType": "*/*",
              "host": "*",
              "pathPattern": ".*\\.puz"
            }
          ]
        }
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
